# Local (Docker Compose)
DATABASE_URL=postgresql://cnpj:cnpj@localhost:5432/cnpj

RFB_BASE_URL=https://arquivos.receitafederal.gov.br/index.php/s/YggdBLfdninEJX9
DATA_DIR=./data
KEEP_DOWNLOADS=false
CHUNK_SIZE=25000
LOG_LEVEL=INFO

# Filtros ETL — carga ampla nacional (padrão atual)
FILTER_ACTIVE_ONLY=true
FILTER_REQUIRE_NOME_FANTASIA=false
FILTER_REQUIRE_TELEFONE=false
FILTER_MIN_POPULATION=0
IBGE_POPULATION_YEAR=2024

# Enriquecimento v2
ENRICHMENT_VERSION=v2
ENRICH_BATCH_SIZE=300
ENRICH_DELAY_SECONDS=0.4
ENRICH_REQUEST_TIMEOUT=15
ENRICH_CONNECT_TIMEOUT=5
ENRICH_NO_SITE_RETRY_DAYS=30
ENRICH_FAILED_RETRY_HOURS=24
ENRICH_MAX_ROUNDS=40
CRAWLER_MAX_PAGES=8
CRAWLER_MAX_BYTES_PER_PAGE=2000000
CRAWLER_DELAY_SECONDS=0.2
SITE_MATCH_THRESHOLD=70

# Qualificação v2
PROSPECT_MIN_CONFIDENCE_SCORE=60
PROSPECT_MIN_LEAD_SCORE=60

# Google Places (opcional — requer chave)
GOOGLE_PLACES_ENABLED=false
# GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_TIMEOUT=15
GOOGLE_PLACES_MIN_MATCH_SCORE=70
GOOGLE_PLACES_MAX_REQUESTS_PER_RUN=500
GOOGLE_PLACES_TTL_DAYS=90

# Providers externos (opcional)
# ENRICH_EXTERNAL_API_PROVIDER=speedio
# ENRICH_EXTERNAL_API_KEY=
# ENRICH_BRASILAPI=true

# API Vercel (opcional)
# API_REQUIRE_AUTH=true
# API_KEY=

# Views permitidas para fila de enriquecimento
# ENRICH_CANDIDATE_VIEW=cnpj.v_prospect_candidates
