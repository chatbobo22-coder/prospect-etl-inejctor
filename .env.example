# Local (Docker Compose)
DATABASE_URL=postgresql://cnpj:cnpj@localhost:5432/cnpj

# Supabase — ETL local/cron (session mode, porta 5432)
# DATABASE_URL=postgresql://postgres:SEU_PASSWORD@db.SEU_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Supabase — Vercel/serverless (transaction mode, porta 6543)
# DATABASE_URL=postgres://postgres.SEU_PROJECT_REF:SEU_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# Supabase — alternativas (usadas se DATABASE_URL estiver vazio)
# POSTGRES_URL_NON_POOLING=postgres://postgres.SEU_PROJECT_REF:SEU_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
# POSTGRES_HOST=db.SEU_PROJECT_REF.supabase.co
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=SEU_PASSWORD
# POSTGRES_DATABASE=postgres
RFB_BASE_URL=https://arquivos.receitafederal.gov.br/index.php/s/YggdBLfdninEJX9
DATA_DIR=/data
KEEP_DOWNLOADS=false
CHUNK_SIZE=25000
DOWNLOAD_CHUNK_BYTES=1048576
REQUEST_TIMEOUT_SECONDS=120
LOG_LEVEL=INFO
# Opcional: limite os tipos no primeiro teste. Vazio processa todos.
# INCLUDE_TYPES=Municipios,Cnaes,Empresas,Estabelecimentos,Simples

# Filtro varejo (padrão: 18 CNAEs abaixo, somente ativas, CNAE principal)
FILTER_ACTIVE_ONLY=true
FILTER_REQUIRE_NOME_FANTASIA=true
FILTER_REQUIRE_TELEFONE=true
FILTER_MIN_POPULATION=100000
IBGE_POPULATION_YEAR=2024
# FILTER_CNAES=4791201,4781400,4782201
# FILTER_UF=PR,SC
# FILTER_CNAE_INCLUDE_SECONDARY=false
# DISABLE_FILTERS=true
